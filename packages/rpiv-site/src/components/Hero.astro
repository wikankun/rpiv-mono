---
import { getWorkflows } from "../lib/workflows";
import SumiInk from "./SumiInk.astro";

const workflows = await getWorkflows();
const showcase = workflows.find((w) => w.showcase) ?? workflows[0];
const stages = showcase.stages;
const N = stages.length;
const loop = showcase.loop;

// Flow rail geometry — a /wf head stamp, then evenly-spaced stage nodes. This
// is the original hero's pipeline rail, upgraded to the workflow flow graphic
// (continuous rail, artifact ticks, a backward review loop).
const RAIL = { vw: 760, vh: 88, y: 44, x0: 92, x1: 716 } as const;
const nodeX = (i: number) => (N <= 1 ? RAIL.x0 : RAIL.x0 + (i * (RAIL.x1 - RAIL.x0)) / (N - 1));
---

<section id="top" class="hero">
	<SumiInk variant="backdrop" />
	<div class="container hero__inner">
		<p class="kicker hero__kicker">§ rpiv-pi · workflow runner</p>

		<h1 class="hero__title">
			<span class="hero__line hero__line--1">research</span>
			<span class="hero__line hero__line--2">design</span>
			<span class="hero__line hero__line--3">ship</span>
		</h1>

		<p class="hero__lede">
			A workflow chains Pi skills into one runnable pipeline. One command runs
			the whole chain. Artifacts flow stage to stage, reviews loop until clean,
			and every run is audited.
		</p>

		<figure
			class="hero__flow"
			aria-label={`The ${showcase.name} workflow, run by one /wf command: ${stages.map((s) => s.name).join(", ")}${loop ? ", with a review loop" : ""}.`}
		>
			<svg viewBox={`0 0 ${RAIL.vw} ${RAIL.vh}`} class="hero__flowSvg" preserveAspectRatio="xMidYMid meet" role="presentation">
				{/* /wf head stamp — the one command that drives the rail */}
				<g>
					<rect x="6" y={RAIL.y - 10} width="56" height="20" rx="2" fill="var(--ink-raised)" stroke="var(--ochre)" stroke-width="1" />
					<rect x="6" y={RAIL.y - 10} width="56" height="20" rx="2" fill="var(--ochre)" opacity="0.16" />
					<text x="34" y={RAIL.y + 4} text-anchor="middle" font-family="var(--font-mono)" font-size="10.5" fill="var(--washi)" letter-spacing="0.02em">/wf</text>
					<path d={`M64,${RAIL.y} L${RAIL.x0 - 16},${RAIL.y}`} stroke="var(--ochre)" stroke-width="0.8" opacity="0.6" stroke-linecap="round" />
					<path d={`M${RAIL.x0 - 20},${RAIL.y - 3} L${RAIL.x0 - 15},${RAIL.y} L${RAIL.x0 - 20},${RAIL.y + 3}`} fill="none" stroke="var(--ochre)" stroke-width="0.8" opacity="0.6" stroke-linecap="round" />
				</g>

				{/* continuous rail */}
				<g fill="none" stroke="var(--sage-deep)" stroke-linecap="round">
					<path d={`M${RAIL.x0},${RAIL.y} L${RAIL.x1},${RAIL.y}`} stroke-width="1" opacity="0.7" />
					<path d={`M${RAIL.x0 + 8},${RAIL.y + 4} L${RAIL.x1 - 8},${RAIL.y + 4}`} stroke-width="0.5" opacity="0.25" />
				</g>

				{/* ochre artifact ticks — one flows into the next stage */}
				{stages.slice(0, -1).map((_, i) => {
					const mx = (nodeX(i) + nodeX(i + 1)) / 2;
					return <circle cx={mx} cy={RAIL.y} r="2.4" fill="var(--ochre)" opacity="0.75" />;
				})}

				{/* backward review loop — ochre arc above the rail */}
				{loop && (() => {
					const fx = nodeX(loop.from);
					const tx = nodeX(loop.to);
					const mid = (fx + tx) / 2;
					const apexY = 14;
					return (
						<g fill="none" stroke-linecap="round">
							<path d={`M${fx},${RAIL.y - 14} Q${mid},${apexY} ${tx},${RAIL.y - 14}`} stroke="var(--ochre)" stroke-width="1.1" opacity="0.7" />
							<path d={`M${fx},${RAIL.y - 11} Q${mid},${apexY + 4} ${tx},${RAIL.y - 11}`} stroke="var(--ochre)" stroke-width="0.5" opacity="0.3" />
							<path d={`M${tx + 6},${RAIL.y - 18} L${tx},${RAIL.y - 14} L${tx + 6},${RAIL.y - 10}`} stroke="var(--ochre)" stroke-width="1" opacity="0.7" />
							<text x={mid} y={apexY - 2} text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--text-distant)" letter-spacing="0.06em">{loop.label}</text>
						</g>
					);
				})()}

				{/* stage nodes — fanout node renders a stacked ghost pair behind it.
				    Each carries --rail-i so it inherits the original rail's
				    left→right unspool stagger. */}
				{stages.map((s, i) => {
					const x = nodeX(i);
					return (
						<g class="hero__node" style={`--rail-i: ${i}`}>
							{s.fanout && (
								<g fill="none" stroke="var(--sage)" stroke-width="0.7" opacity="0.32" stroke-dasharray="2 2">
									<circle cx={x - 3.5} cy={RAIL.y - 3.5} r="9" />
									<circle cx={x + 3.5} cy={RAIL.y + 3.5} r="9" />
								</g>
							)}
							<circle cx={x} cy={RAIL.y} r="13" fill="none" stroke="var(--sage)" stroke-width="0.7" opacity="0.4" />
							<circle cx={x} cy={RAIL.y} r="9" fill="var(--ink)" stroke="var(--sage)" stroke-width="1.1" />
							<circle cx={x} cy={RAIL.y} r="9" fill="var(--sage)" opacity="0.16" />
							<text x={x} y={RAIL.y + 30} text-anchor="middle" font-family="var(--font-mono)" font-size="10.5" fill="var(--text-quiet)" letter-spacing="0.02em">{s.name}</text>
						</g>
					);
				})}
			</svg>
		</figure>

		<p class="hero__cta">
			<a href="#install" class="hero__link">install&nbsp;↓</a>
		</p>
	</div>
</section>

<style>
	.hero {
		min-height: 92dvh;
		display: flex;
		align-items: center;
		padding: var(--space-10) 0 var(--space-9);
		position: relative;
		overflow: hidden;
	}
	.hero__inner { position: relative; z-index: 1; }
	.hero__title {
		font-size: var(--type-h1);
		line-height: 0.95;
		margin-bottom: var(--space-6);
	}
	.hero__line {
		display: block;
	}

	/* ── Page-load stagger ──
	   Single orchestrated reveal: kicker, then three title lines (offset 80ms each),
	   then lede, then flow-rail nodes (each 60ms apart), then CTA.
	   Uses the system tokens (--ease-ink, --dur-ink) so motion stays on-vocabulary. */
	@keyframes hero-rise {
		from { opacity: 0; transform: translateY(8px); }
		to   { opacity: 1; transform: translateY(0);   }
	}
	.hero__kicker,
	.hero__line,
	.hero__lede,
	.hero__node,
	.hero__cta {
		opacity: 0;
		animation: hero-rise var(--dur-ink) var(--ease-ink) forwards;
	}
	.hero__kicker  { animation-delay:   0ms; }
	.hero__line--1 { animation-delay: 120ms; }
	.hero__line--2 { animation-delay: 200ms; }
	.hero__line--3 { animation-delay: 280ms; }
	.hero__lede    { animation-delay: 460ms; }
	.hero__node    { animation-delay: calc(620ms + var(--rail-i, 0) * 60ms); }
	.hero__cta     { animation-delay: 1080ms; }

	@media (prefers-reduced-motion: reduce) {
		.hero__kicker,
		.hero__line,
		.hero__lede,
		.hero__node,
		.hero__cta {
			opacity: 1;
			animation: none;
		}
	}
	.hero__lede {
		font-family: var(--font-serif);
		max-width: 56ch;
		color: var(--text-quiet);
		font-size: var(--type-lead);
		line-height: var(--leading-body);
		margin-bottom: var(--space-6);
	}

	/* ── Flow rail — the pipeline graphic in the rail's place. Sits closer to the
	   lede (its visual proof) than to the CTA, so the headline + lede + flow read
	   as one group with breathing room before install. ── */
	.hero__flow {
		margin: 0 0 var(--space-8);
		/* Definite (vw-based) width so the row-flex shrink-to-fit sizes .hero__inner
		   to the rail and centres it — the original mechanism, where the rail's
		   own width drove the column. Kept near the original /skill: chip rail's
		   width (~900px) so the column shrinks and indents the same amount: a wider
		   figure would shrink the column less and push the content flush to the
		   menu edge. A % width would collapse under shrink-to-fit. */
		width: min(900px, 92vw);
	}
	.hero__flowSvg { width: 100%; height: auto; display: block; overflow: visible; }

	.hero__cta {
		font-family: var(--font-mono);
		font-size: var(--type-small);
		margin: 0;
	}
	.hero__link {
		color: var(--ochre);
		border-bottom-color: var(--kuro);
	}
	@media (max-width: 720px) {
		.hero { min-height: auto; padding: var(--space-8) 0 var(--space-7); }
	}
</style>
