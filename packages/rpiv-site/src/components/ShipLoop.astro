---
import { ARTIFACT_WRITE_SITES, getCodeReviewSkills } from "../lib/skills";
const skills = await getCodeReviewSkills();
---

<section id="review">
	<div class="container">
		<p class="kicker">§ code review · verified findings</p>
		<h2>Findings, not opinions.</h2>
		<p class="cr__lede">
			Point it at staged work, a single hash, or a whole branch.
			<strong>Quality</strong>, <strong>security</strong>, and
			<strong>dependencies</strong> are read in parallel. Every cited
			<code>file:line</code> is opened a second time. You get back one markdown
			artifact with a clear <code>status</code> at the top and every finding
			tied to a verification mark.
		</p>

		<figure class="cr-flow" aria-label="Code review pipeline: commit produces a diff that the code-review skill processes into a verified report">
			{/* ── BLOCK 01 — input (commit / staged work) ── */}
			<article class="cr-block cr-block--input">
				<header class="cr-block__head">
					<p class="cr-kicker mono">01 · input</p>
					<h3 class="mono cr-name">/skill:commit</h3>
				</header>
				<p class="cr-desc">
					A staged diff or your working tree. Whatever you want a fresh pair of
					eyes on.
				</p>

				{/* mini story-SVG: git-diff-stat style with +/− bars */}
				<svg class="cr-mini" viewBox="0 0 200 116" width="200" height="116" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
					<g font-family="var(--font-mono)" font-size="9" fill="var(--text-distant)" letter-spacing="0.02em">
						<text x="6" y="14">src/auth.ts</text>
						<text x="6" y="40">src/api.ts</text>
						<text x="6" y="66">src/util.ts</text>
						<text x="6" y="92">README.md</text>
					</g>
					{/* +/− stat bars: sage = additions, ochre = deletions */}
					<g stroke-linecap="round" stroke-width="3">
						{/* row 1 */}
						<line x1="98"  y1="11" x2="138" y2="11" stroke="var(--sage)"  opacity="0.8" />
						<line x1="140" y1="11" x2="160" y2="11" stroke="var(--ochre)" opacity="0.7" />
						{/* row 2 */}
						<line x1="98"  y1="37" x2="118" y2="37" stroke="var(--sage)"  opacity="0.8" />
						<line x1="120" y1="37" x2="128" y2="37" stroke="var(--ochre)" opacity="0.7" />
						{/* row 3 */}
						<line x1="98"  y1="63" x2="166" y2="63" stroke="var(--sage)"  opacity="0.8" />
						{/* row 4 */}
						<line x1="98"  y1="89" x2="110" y2="89" stroke="var(--sage)"  opacity="0.8" />
					</g>
					{/* tally */}
					<g font-family="var(--font-mono)" font-size="9" letter-spacing="0.04em">
						<text x="170" y="14"  fill="var(--sage)"  text-anchor="end">+24</text>
						<text x="170" y="40"  fill="var(--sage)"  text-anchor="end">+12</text>
						<text x="170" y="66"  fill="var(--sage)"  text-anchor="end">+34</text>
						<text x="170" y="92"  fill="var(--sage)"  text-anchor="end">+6</text>
					</g>
					{/* footer summary */}
					<line x1="6" y1="100" x2="194" y2="100" stroke="var(--rule)" stroke-width="0.6" />
					<text x="6"   y="112" font-family="var(--font-mono)" font-size="8" fill="var(--text-distant)" letter-spacing="0.16em">4 FILES</text>
					<text x="194" y="112" font-family="var(--font-mono)" font-size="8" fill="var(--sage)"        letter-spacing="0.16em" text-anchor="end">+76 / −28</text>
				</svg>

				<p class="cr-meta mono">
					<span class="cr-meta__arrow">→</span>
					<code>commit</code>
					<span class="cr-meta__sep">·</span>
					<code>staged</code>
					<span class="cr-meta__sep">·</span>
					<code>working</code>
				</p>
			</article>

			{/* ── CONNECTOR 01 → 02 ── */}
			<div class="cr-link" aria-hidden="true">
				<svg class="cr-link__brush" viewBox="0 0 120 80" width="120" height="80" preserveAspectRatio="xMidYMid meet">
					<g fill="none" stroke-linecap="round">
						<path d="M8,32 Q42,26 100,30" stroke="var(--ochre)" stroke-width="0.5" opacity="0.32" />
						<path d="M6,40 Q40,36 102,40" stroke="var(--washi-soft)" stroke-width="1.6" opacity="0.85" />
						<path d="M8,48 Q42,44 100,46" stroke="var(--sage)" stroke-width="0.5" opacity="0.22" />
						<path d="M96,32 L112,40 L96,48" stroke="var(--washi-soft)" stroke-width="1.4" opacity="0.85" />
						<path d="M97,34 L109,40 L97,46" stroke="var(--ochre)" stroke-width="0.5" opacity="0.32" />
					</g>
					<text x="60" y="68" text-anchor="middle"
						font-family="var(--font-mono)" font-size="9"
						fill="var(--text-distant)" letter-spacing="0.18em">SCOPE</text>
				</svg>
			</div>

			{/* ── BLOCK 02 — HERO code-review with lens architecture ── */}
			<article class="cr-block cr-block--hero">
				<div class="cr-hero__wash" aria-hidden="true"></div>

				<header class="cr-block__head">
					<p class="cr-kicker mono cr-kicker--hero">02 · review</p>
					<h3 class="mono cr-name cr-name--hero">/skill:code-review</h3>
				</header>

				{/* THE LENS DIAGRAM — three lanes (Quality, Security, Dependencies) running
				    in parallel through specialist row-only agents, converging on a
				    verification gate before emitting a single artifact. */}
				<svg class="cr-lens" viewBox="0 0 380 168" width="380" height="168" aria-label="three lenses run in parallel and converge through verification" preserveAspectRatio="xMidYMid meet">
					<defs>
						<marker id="cr-arrow" viewBox="0 0 10 10" refX="9" refY="5"
							markerWidth="6" markerHeight="6" orient="auto">
							<path d="M0,0 L10,5 L0,10 z" fill="var(--washi-soft)" opacity="0.85" />
						</marker>
					</defs>

					{/* diff source on the far left */}
					<g>
						<rect x="14" y="64" width="46" height="40" rx="2"
							fill="var(--ink)" stroke="var(--sage)" stroke-width="0.8" opacity="0.9" />
						<line x1="20" y1="74" x2="54" y2="74" stroke="var(--sage)" stroke-width="0.6" opacity="0.7" />
						<line x1="20" y1="80" x2="48" y2="80" stroke="var(--sage)" stroke-width="0.6" opacity="0.5" />
						<line x1="20" y1="86" x2="52" y2="86" stroke="var(--sage)" stroke-width="0.6" opacity="0.5" />
						<line x1="20" y1="92" x2="42" y2="92" stroke="var(--sage)" stroke-width="0.6" opacity="0.5" />
						<text x="37" y="118" text-anchor="middle"
							font-family="var(--font-mono)" font-size="8"
							fill="var(--text-distant)" letter-spacing="0.14em">DIFF</text>
					</g>

					{/* fan-out brushstrokes from diff to three lens nodes */}
					<g fill="none" stroke="var(--washi-soft)" stroke-linecap="round" opacity="0.7">
						<path d="M60,76 Q98,52 138,40"  stroke-width="0.8" stroke-dasharray="3 2" />
						<path d="M60,84 L138,84"        stroke-width="0.8" stroke-dasharray="3 2" />
						<path d="M60,92 Q98,116 138,128" stroke-width="0.8" stroke-dasharray="3 2" />
					</g>

					{/* three lens lanes — labels sit ABOVE each circle on a clear
					    horizontal band. Side-positioned labels (the previous
					    layout) were bisected by the arcs sweeping from each
					    lens toward verify, since those arcs occupy exactly the
					    y-band where right-side labels would sit. */}
					{[
						{ y: 40,  letter: "Q", label: "quality",      labelY: 20,  tint: "var(--sage)" },
						{ y: 84,  letter: "S", label: "security",     labelY: 64,  tint: "var(--ochre)" },
						{ y: 128, letter: "D", label: "dependencies", labelY: 108, tint: "var(--sage)" },
					].map((lane) => (
						<g>
							{/* lane node — labeled circle */}
							<circle cx={150} cy={lane.y} r="14" fill="none" stroke={lane.tint} stroke-width="0.6" opacity="0.4" />
							<circle cx={150} cy={lane.y} r="11" fill="var(--ink-raised)" stroke={lane.tint} stroke-width="1.1" />
							<circle cx={150} cy={lane.y} r="11" fill={lane.tint} opacity="0.18" />
							<text x={150} y={lane.y + 3.5} text-anchor="middle"
								font-family="var(--font-mono)" font-size="11"
								fill="var(--washi)" letter-spacing="0.04em">{lane.letter}</text>
							{/* lane label — centered above the circle, never collides
							    with the arc sweeping from this lens toward verify */}
							<text x={150} y={lane.labelY} text-anchor="middle"
								font-family="var(--font-mono)" font-size="9"
								fill="var(--text-quiet)" letter-spacing="0.06em">{lane.label}</text>
							{/* outbound arrow toward verify — terminates 2px outside the
							    hex's new left tip (235), matching the larger gate. */}
							<path d={`M165,${lane.y} Q207,${lane.y} 233,84`}
								fill="none" stroke="var(--washi-soft)" stroke-width="0.9" opacity="0.65" stroke-linecap="round" />
						</g>
					))}

					{/* verification gate — ochre hexagon (the structural-resistance
					    gate). Sized 50×30 (up from 40×24) so the "verify" label
					    sits with comfortable padding on all sides instead of
					    grazing the angled edges. */}
					<g>
						<polygon points="247,69 273,69 285,84 273,99 247,99 235,84"
							fill="var(--ink-raised)" stroke="var(--ochre)" stroke-width="1.3" />
						<polygon points="247,69 273,69 285,84 273,99 247,99 235,84"
							fill="var(--ochre)" opacity="0.20" />
						<text x="260" y="87" text-anchor="middle"
							font-family="var(--font-mono)" font-size="8.5"
							fill="var(--washi)" letter-spacing="0.04em">verify</text>
						{/* caption pushed below the D-lane arc's sweep zone so the
						    arc no longer cuts through "re-read file:line" */}
						<text x="260" y="124" text-anchor="middle"
							font-family="var(--font-mono)" font-size="7.5"
							fill="var(--text-distant)" letter-spacing="0.16em">re-read file:line</text>
					</g>

					{/* arrow from verify → report */}
					<path d="M285,84 L320,84"
						fill="none" stroke="var(--washi-soft)" stroke-width="1" opacity="0.85"
						stroke-linecap="round" marker-end="url(#cr-arrow)" />

					{/* report node on the right edge */}
					<g>
						<rect x="324" y="64" width="44" height="40" rx="2"
							fill="var(--ink-raised)" stroke="var(--ochre)" stroke-width="1.1" />
						<rect x="324" y="64" width="44" height="40" rx="2"
							fill="var(--ochre)" opacity="0.14" />
						<line x1="330" y1="74" x2="362" y2="74" stroke="var(--washi-soft)" stroke-width="0.6" opacity="0.85" />
						<line x1="330" y1="80" x2="356" y2="80" stroke="var(--washi-soft)" stroke-width="0.6" opacity="0.55" />
						<line x1="330" y1="86" x2="358" y2="86" stroke="var(--washi-soft)" stroke-width="0.6" opacity="0.55" />
						<line x1="330" y1="92" x2="350" y2="92" stroke="var(--washi-soft)" stroke-width="0.6" opacity="0.55" />
						<text x="346" y="118" text-anchor="middle"
							font-family="var(--font-mono)" font-size="8"
							fill="var(--text-distant)" letter-spacing="0.14em">REPORT</text>
					</g>

					{/* legend strip across the bottom — hand-drawn lens key */}
					<g font-family="var(--font-mono)" font-size="7.5"
						fill="var(--text-distant)" letter-spacing="0.14em">
						<text x="14" y="158">3 LENSES · PARALLEL · ROW-ONLY</text>
					</g>
				</svg>

				<p class="cr-desc cr-desc--hero">
					Three subagents run on your diff in parallel: one checks
					<strong>quality</strong>, one checks <strong>security</strong>, one
					checks <strong>dependencies</strong>, each along its own dimensions.
					They return flat findings, not prose. A final pass filters out
					false positives.
				</p>

				{/* Coverage / scope ledger — what review covers / what it deliberately won't */}
				<div class="cr-trade">
					<div class="cr-trade__col cr-trade__col--gain">
						<p class="mono cr-trade__label">covers</p>
						<ul class="cr-trade__list">
							<li>quality, security, and dependency drift</li>
							<li>peer comparison against precedents</li>
							<li>findings pinned to verified <code>file:line</code></li>
						</ul>
					</div>
					<div class="cr-trade__col cr-trade__col--cost">
						<p class="mono cr-trade__label">won&rsquo;t</p>
						<ul class="cr-trade__list">
							<li>edit your code. It surfaces, you decide.</li>
							<li>guess at intent. Run an advisor pass first.</li>
						</ul>
					</div>

				</div>

				<p class="cr-meta mono">
					<span class="cr-meta__arrow">→</span>
					<code>.rpiv/artifacts/reviews/</code>
					<span class="cr-meta__sep">·</span>
					feeds <code>revise</code> or <code>commit</code>
				</p>

				{/* large corner ornament — sumi-ink calligraphy curl */}
				<svg class="cr-hero__ornament" viewBox="0 0 160 110" width="160" height="110" aria-hidden="true">
					<g fill="none" stroke="var(--ochre)" stroke-linecap="round" opacity="0.45">
						<path d="M14,100 q22,-50 70,-72 q44,-20 70,28" stroke-width="1.1" />
						<path d="M26,104 q20,-40 62,-58 q34,-14 60,16" stroke-width="0.6" opacity="0.55" />
						<path d="M40,108 q16,-26 48,-40" stroke-width="0.4" opacity="0.4" />
						<circle cx="148" cy="50" r="2" />
						<circle cx="46"  cy="86" r="1.4" opacity="0.7" />
						<circle cx="106" cy="26" r="1.2" opacity="0.6" />
					</g>
				</svg>
			</article>

			{/* ── CONNECTOR 02 → 03 ── */}
			<div class="cr-link" aria-hidden="true">
				<svg class="cr-link__brush" viewBox="0 0 120 80" width="120" height="80" preserveAspectRatio="xMidYMid meet">
					<g fill="none" stroke-linecap="round">
						<path d="M8,32 Q42,26 100,30" stroke="var(--ochre)" stroke-width="0.5" opacity="0.32" />
						<path d="M6,40 Q40,36 102,40" stroke="var(--washi-soft)" stroke-width="1.6" opacity="0.85" />
						<path d="M8,48 Q42,44 100,46" stroke="var(--sage)" stroke-width="0.5" opacity="0.22" />
						<path d="M96,32 L112,40 L96,48" stroke="var(--washi-soft)" stroke-width="1.4" opacity="0.85" />
						<path d="M97,34 L109,40 L97,46" stroke="var(--ochre)" stroke-width="0.5" opacity="0.32" />
					</g>
					<text x="60" y="68" text-anchor="middle"
						font-family="var(--font-mono)" font-size="9"
						fill="var(--text-distant)" letter-spacing="0.18em">REPORT</text>
				</svg>
			</div>

			{/* ── BLOCK 03 — output (review report artifact) ── */}
			<article class="cr-block cr-block--output">
				<header class="cr-block__head">
					<p class="cr-kicker mono">03 · output</p>
					<h3 class="mono cr-name">review&nbsp;report</h3>
				</header>
				<p class="cr-desc">
					One markdown file. Status at the top, then every finding with the
					evidence behind it.
				</p>

				{/* mini report mock — actual structure from review.md template */}
				<svg class="cr-mini cr-mini--report" viewBox="0 0 220 188" width="220" height="188" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
					{/* page card */}
					<rect x="6" y="6" width="208" height="176" rx="2"
						fill="var(--ink)" stroke="var(--rule-strong)" stroke-width="0.8" />

					{/* title bar */}
					<text x="14" y="22" font-family="var(--font-mono)" font-size="8"
						fill="var(--text-distant)" letter-spacing="0.16em">REVIEW · feature/auth</text>

					{/* status badge — ochre "needs_changes" pill */}
					<rect x="14" y="32" width="92" height="18" rx="9"
						fill="var(--ink-raised)" stroke="var(--ochre)" stroke-width="1" />
					<rect x="14" y="32" width="92" height="18" rx="9"
						fill="var(--ochre)" opacity="0.18" />
					<text x="60" y="44.5" text-anchor="middle"
						font-family="var(--font-mono)" font-size="9"
						fill="var(--washi)" letter-spacing="0.04em">needs_changes</text>

					{/* hairline separator */}
					<line x1="14" y1="62" x2="206" y2="62" stroke="var(--rule)" stroke-width="0.6" />

					{/* severity row — three dots with counts */}
					<g font-family="var(--font-mono)" font-size="9" letter-spacing="0.02em">
						<text x="14" y="78" fill="var(--text-distant)" letter-spacing="0.14em">SEVERITY</text>
						<g transform="translate(14,90)">
							{/* critical — red dot */}
							<circle cx="6" cy="6" r="4.5" fill="var(--alert)" opacity="0.9" />
							<text x="16" y="9" fill="var(--text-quiet)">2</text>
							{/* important — ochre dot */}
							<circle cx="42" cy="6" r="4.5" fill="var(--ochre)" opacity="0.95" />
							<text x="52" y="9" fill="var(--text-quiet)">5</text>
							{/* suggestion — sage dot */}
							<circle cx="78" cy="6" r="4.5" fill="var(--sage)" opacity="0.95" />
							<text x="88" y="9" fill="var(--text-quiet)">11</text>
							{/* discussion — washi dim */}
							<circle cx="114" cy="6" r="4.5" fill="var(--washi-soft)" opacity="0.5" />
							<text x="124" y="9" fill="var(--text-quiet)">3</text>
						</g>
					</g>

					{/* verification row — ✓ − ✗ */}
					<g font-family="var(--font-mono)" font-size="9">
						<text x="14" y="118" fill="var(--text-distant)" letter-spacing="0.14em">VERIFY</text>
						<g transform="translate(14,128)">
							<text x="0"  y="9" fill="var(--sage)"  >✓</text><text x="10" y="9" fill="var(--text-quiet)">17</text>
							<text x="40" y="9" fill="var(--ochre)" >−</text><text x="50" y="9" fill="var(--text-quiet)">3</text>
							<text x="80" y="9" fill="var(--alert)"      >✗</text><text x="90" y="9" fill="var(--text-quiet)">1</text>
						</g>
					</g>

					{/* finding rows — three short bars to suggest the body */}
					<g>
						<line x1="14" y1="156" x2="22" y2="156" stroke="var(--alert)"      stroke-width="2" stroke-linecap="round" />
						<line x1="26" y1="156" x2="190" y2="156" stroke="var(--washi-soft)" stroke-width="0.7" opacity="0.6" />
						<line x1="14" y1="166" x2="22" y2="166" stroke="var(--ochre)" stroke-width="2" stroke-linecap="round" />
						<line x1="26" y1="166" x2="170" y2="166" stroke="var(--washi-soft)" stroke-width="0.7" opacity="0.55" />
						<line x1="14" y1="176" x2="22" y2="176" stroke="var(--sage)"  stroke-width="2" stroke-linecap="round" />
						<line x1="26" y1="176" x2="180" y2="176" stroke="var(--washi-soft)" stroke-width="0.7" opacity="0.55" />
					</g>
				</svg>

				<p class="cr-meta mono">
					<span class="cr-meta__arrow">→</span>
					<code>.rpiv/artifacts/reviews/</code>
				</p>
			</article>
		</figure>

		{/* secondary skills detail rows (commit + code-review) */}
		<div class="cr__rows-head">
			<p class="kicker">§ skills · {skills.length}</p>
		</div>
		<ol class="cr__rows">
			{skills.map((skill) => {
				const artifact = ARTIFACT_WRITE_SITES[skill.data.name];
				const isReview = skill.data.name === "code-review";
				return (
					<li class:list={["cr__row", isReview && "cr__row--featured"]}>
						<header class="cr__rowHead">
							<span class={isReview ? "chip chip--ochre" : "chip"}>
								/skill:{skill.data.name}
							</span>
							{isReview && <span class="chip chip--sage">centerpiece</span>}
							{skill.data["disable-model-invocation"] && <span class="chip">manual only</span>}
						</header>
						<p class="cr__rowDesc">{skill.tagline}</p>
						{(skill.data["argument-hint"] || artifact) && (
							<p class="mono cr__rowMeta">
								{skill.data["argument-hint"] && <><span class="cr__metaLabel">arg</span>{skill.data["argument-hint"]}</>}
								{skill.data["argument-hint"] && artifact && <span class="cr__sep">·</span>}
								{artifact && <><span class="cr__metaLabel">→</span><code>{artifact}</code></>}
							</p>
						)}
					</li>
				);
			})}
		</ol>
	</div>
</section>

<style>
	#review h2 { margin-bottom: var(--space-5); }

	.cr__lede {
		color: var(--text-quiet);
		margin-bottom: var(--space-7);
		max-width: 64ch;
	}
	.cr__lede strong { color: var(--washi); font-weight: 400; }
	.cr__lede code { color: var(--ochre); background: transparent; }

	/* ─── 3-block hero ─── */
	.cr-flow {
		margin: 0 0 var(--space-8);
		padding: var(--space-7) 0;
		border-top: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule);
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4);
		align-items: stretch;
	}
	@media (min-width: 920px) {
		.cr-flow {
			grid-template-columns: 0.95fr 80px 2fr 80px 0.95fr;
			gap: var(--space-3);
			align-items: stretch;
		}
	}

	.cr-block {
		position: relative;
		padding: var(--space-5);
		background: var(--ink-raised);
		border-top: 1px solid var(--rule);
		border-left: 1px solid var(--sage-deep);
		border-right: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule-strong);
		display: flex;
