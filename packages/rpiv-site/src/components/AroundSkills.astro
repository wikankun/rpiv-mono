---
// §5 — the skills that surround a flow. Standalone skills grouped by their
// moment relative to a run. A spare "where they fit" schematic answers the
// spatial question; the grouped cards carry the detail.
import { getAroundSkills, type AroundSkill } from "../lib/around-skills";

const skills = await getAroundSkills();
const GROUPS = [
	{ key: "before", label: "Before the run", hint: "frame the work before a flow starts" },
	{ key: "context", label: "Standing context", hint: "per-folder docs the agent reads as it works" },
	{ key: "across", label: "Across sessions", hint: "save a run's state, pick it up later" },
	{ key: "edges", label: "Around the edges", hint: "direction going in, release coming out" },
] as const;
const byMoment = (m: string): AroundSkill[] => skills.filter((s) => s.moment === m);
---

<section id="around">
	<div class="container">
		<p class="kicker">§ around the flow · before, beside, after</p>
		<h2>The skills you reach for around a run.</h2>
		<p class="ar__lede">
			These aren&rsquo;t stages of any flow. They frame the work before it
			starts, hold context underneath it, bridge it across sessions, and record
			it when it lands.
		</p>

		<figure class="ar-fig" aria-label="Where the standalone skills fit relative to a run: discover and explore feed in before; annotate-guidance holds standing context whose freshness or continuation the flow manages; create-handoff and resume-handoff bridge a paused run across sessions; changelog records it after.">
			{/* Symmetric grid: everything balances about the centre axis (x=440).
			    Four evenly-spaced rail nodes (350·410·470·530); BEFORE feeds in
			    from the left and AFTER exits right as mirror images; the standing-
			    context band and the across-sessions bridge are centred under the
			    rail. */}
			<svg viewBox="0 0 880 170" class="ar-svg" preserveAspectRatio="xMidYMid meet" role="presentation">
				{/* the run */}
				<text x="440" y="22" text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--text-distant)" letter-spacing="0.06em">a /wf run</text>
				<g fill="none" stroke="var(--sage-deep)" stroke-linecap="round">
					<path d="M332,58 L548,58" stroke-width="1.1" opacity="0.8" />
					<path d="M340,62 L540,62" stroke-width="0.5" opacity="0.3" />
				</g>
				{[350, 410, 470, 530].map((x) => (
					<g>
						<circle cx={x} cy="58" r="7" fill="none" stroke="var(--sage)" stroke-width="0.7" opacity="0.55" />
						<circle cx={x} cy="58" r="4.5" fill="var(--ink)" stroke="var(--sage)" stroke-width="1" />
						<circle cx={x} cy="58" r="4.5" fill="var(--sage)" opacity="0.16" />
					</g>
				))}

				{/* before — feeds into the head */}
				<text x="40" y="48" font-family="var(--font-mono)" font-size="11" fill="var(--text-distant)" letter-spacing="0.14em">BEFORE</text>
				<text x="40" y="68" font-family="var(--font-mono)" font-size="11" fill="var(--sage)" letter-spacing="0.02em">discover · explore</text>
				<g fill="none" stroke="var(--ochre)" stroke-linecap="round" opacity="0.7">
					<path d="M186,66 Q258,60 326,58" stroke-width="1.1" stroke-dasharray="4 3" />
					<path d="M320,54 L327,58 L320,62" stroke-width="1" />
				</g>

				{/* after — flows out of the tail (mirror of before) */}
				<text x="840" y="48" text-anchor="end" font-family="var(--font-mono)" font-size="11" fill="var(--text-distant)" letter-spacing="0.14em">AFTER</text>
				<text x="840" y="68" text-anchor="end" font-family="var(--font-mono)" font-size="11" fill="var(--sage)" letter-spacing="0.02em">changelog</text>
				<g fill="none" stroke="var(--ochre)" stroke-linecap="round" opacity="0.7">
					<path d="M554,58 Q622,60 694,66" stroke-width="1.1" stroke-dasharray="4 3" />
					<path d="M688,62 L695,66 L688,70" stroke-width="1" />
				</g>

				{/* standing context — band beneath the whole run */}
				<g fill="none" stroke="var(--sage)" stroke-linecap="round" opacity="0.62">
					<path d="M350,76 L350,82 L530,82 L530,76" stroke-width="0.9" />
				</g>
				<text x="440" y="98" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--text-distant)" letter-spacing="0.04em">standing context · fresh or continue, managed by the flow</text>

				{/* across sessions — bridge */}
				<path d="M384,128 Q440,116 496,128" fill="none" stroke="var(--ochre)" stroke-width="1" opacity="0.7" stroke-dasharray="3 3" />
				<text x="440" y="142" text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--text-quiet)" letter-spacing="0.02em">create-handoff ⇢ resume-handoff</text>
				<text x="440" y="158" text-anchor="middle" font-family="var(--font-mono)" font-size="9.5" fill="var(--text-distant)" letter-spacing="0.06em">across sessions</text>
			</svg>
		</figure>

		{GROUPS.map((group) => (
			<div class="ar__group">
				<header class="ar__groupHead">
					<h3 class="mono ar__groupName">{group.label}</h3>
					<span class="ar__groupHint">{group.hint}</span>
				</header>
				<div class="ar__cards" role="list">
					{byMoment(group.key).map((s) => (
						<a class="ar-card" role="listitem" href={`/docs/reference/skills/${s.name}`}>
							<span class="ar-card__head">
								<span class="chip chip--sage">/skill:{s.name}</span>
								<span class="ar-card__out mono">
									<span class="ar-card__lead" aria-hidden="true">↳</span>
									{s.output}
								</span>
							</span>
							<p class="ar-card__role">{s.role}</p>
						</a>
					))}
				</div>
			</div>
		))}
	</div>
</section>

<style>
	.ar__lede {
		font-family: var(--font-serif);
		max-width: 58ch;
		color: var(--text-quiet);
		font-size: var(--type-lead);
		line-height: var(--leading-body);
		margin: var(--space-4) 0 var(--space-7);
		text-wrap: pretty;
	}

	.ar-fig { margin: var(--space-5) 0 var(--space-8); }
	.ar-svg { width: 100%; max-width: 900px; height: auto; display: block; margin: 0 auto; overflow: visible; }

	.ar__group { margin-bottom: var(--space-6); }
	.ar__groupHead {
		display: flex;
		align-items: baseline;
		gap: var(--space-3);
		margin-bottom: var(--space-4);
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--rule-strong);
	}
	.ar__groupName { font-size: var(--type-h3); color: var(--text); margin: 0; }
	.ar__groupHint {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--type-small);
		color: var(--text-distant);
	}

	.ar__cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: var(--space-4);
	}

	.ar-card {
		/* Canonical two-tone card edge — recessed top/sides (--rule), weighted
		   base (--rule-strong) — matching the global .card hairline signature.
		   These cards link to each skill's reference page, so they carry a quiet
		   ink-warm hover that lifts the base edge toward sage. */
		position: relative;
		overflow: hidden;
		border-top: 1px solid var(--rule);
		border-left: 1px solid var(--rule);
		border-right: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule-strong);
		border-radius: var(--radius-sm);
		padding: var(--space-4) var(--space-5) var(--space-5);
		background: var(--ink-raised);
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		color: inherit;
		text-decoration: none;
		transition:
			background var(--dur-quick) var(--ease-ink),
			border-color var(--dur-quick) var(--ease-ink),
			transform var(--dur-quick) var(--ease-ink);
	}
	/* Atmospheric depth — the same radial wash the global .card carries, which
	   the bespoke around-cards otherwise miss; it warms further on hover. */
	.ar-card::before {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			radial-gradient(1200px 200px at 30% 0%, rgba(168, 137, 108, 0.05), transparent 60%),
			radial-gradient(800px 200px at 80% 100%, rgba(138, 149, 128, 0.035), transparent 60%);
		mix-blend-mode: lighten;
		opacity: 0.85;
		transition: opacity var(--dur-quick) var(--ease-ink);
	}
	.ar-card:hover,
	.ar-card:focus-visible {
		background: var(--ink-muted);
		border-bottom-color: var(--sage-deep);
		transform: translateY(-1px);
	}
	.ar-card:focus-visible {
		outline: 1px solid var(--sage-deep);
		outline-offset: 2px;
	}
	.ar-card:hover::before,
	.ar-card:focus-visible::before { opacity: 1; }
	.ar-card:hover .chip--sage,
	.ar-card:focus-visible .chip--sage { border-color: var(--sage); }

	.ar-card__head {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: var(--space-1) var(--space-2);
		padding-bottom: var(--space-3);
		border-bottom: 1px solid var(--rule);
	}
	.ar-card__head .chip { white-space: nowrap; }
	.ar-card__out {
		min-width: 0;
		display: inline-flex;
		align-items: baseline;
		gap: var(--space-1);
		font-size: var(--type-micro);
		color: var(--text-distant);
		letter-spacing: 0.02em;
		text-align: right;
	}
	/* "leads to" glyph — ties the produced artifact/effect to the skill rather
	   than letting the path float orphaned at the far edge. */
	.ar-card__lead { color: var(--sage-deep); }
	.ar-card__role {
		position: relative;
		font-family: var(--font-serif);
		font-size: var(--type-base);
		line-height: var(--leading-snug);
		color: var(--text-quiet);
		margin: 0;
		text-wrap: pretty;
	}

	@media (max-width: 720px) {
		.ar__cards { grid-template-columns: 1fr; }
	}
</style>
