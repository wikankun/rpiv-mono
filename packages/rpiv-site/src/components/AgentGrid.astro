---
import { getAgentsByTier, type CapabilityTier } from "../lib/agents";
import AgentCard from "./AgentCard.astro";
import SumiInk from "./SumiInk.astro";

const groups = await getAgentsByTier();

const TIER_META: Record<CapabilityTier, { label: string; note: string; cap: string }> = {
	locator:    { label: "Locators",                note: "where. No file content access.",                                       cap: "find" },
	analyzer:   { label: "Analyzers",               note: "how. Reads file content, plus git history via precedent-locator.",     cap: "read" },
	external:   { label: "External agents",         note: "+ web search and fetch",                                               cap: "web"  },
	specialist: { label: "Code-review specialists", note: "Pipe-delimited findings, never prose.",                                cap: "rows" },
};
---

<section id="agents">
	<div class="container">
		<p class="kicker">§ subagents · 13 across 4 tiers</p>
		<h2>Specialists, not generalists.</h2>
		<p class="agents__lede">
			Skills do orchestration. Agents do one narrow thing. Each is isolated,
			each is read-only, each tier is defined by its tool allowlist. Code-review&rsquo;s
			specialists return rows of pipe-delimited findings, never prose, so
			verification stays mechanical.
		</p>

		<SumiInk variant="divider" />

		<div class="ladder" role="list">
			{groups.map(({ tier, agents }, tierIdx) => agents.length > 0 && (
				<div class="ladder__rung" role="listitem" data-solo={agents.length === 1 ? "true" : "false"}>
					<div class="rung__label">
						<p class="rung__num mono">tier {String(tierIdx + 1).padStart(2, "0")}</p>
						<h3 class="mono rung__name">{TIER_META[tier].label}</h3>
						<p class="rung__note">{TIER_META[tier].note}</p>
						<p class="rung__count mono">
							<span class="rung__count-num">{agents.length}</span>
							<span class="rung__count-word">{agents.length === 1 ? "agent" : "agents"}</span>
						</p>

						{agents.length > 3 && (
							<div class="rung__pager"
								role="status"
								aria-label={`${agents.length - 3} more agent${agents.length - 3 === 1 ? "" : "s"} hidden — scroll horizontally to reveal`}>
								<div class="rung__pager-bars" aria-hidden="true">
									{Array.from({ length: agents.length }, (_, i) => (
										<span class:list={["rung__pager-bar", i < 3 && "is-visible"]} />
									))}
								</div>
								<p class="mono rung__pager-cap" aria-hidden="true">
									scroll&nbsp;<span class="rung__pager-arrow">→</span>&nbsp;
									<span class="rung__pager-num">{agents.length - 3}</span> hidden
								</p>
							</div>
						)}
					</div>

					<div class="rung__cells">
						<div class="rung__cards" role="list" data-overflow={agents.length > 3 ? "true" : "false"}>
							{agents.map((agent) => (
								<div role="listitem" class="rung__card-wrap"><AgentCard agent={agent} /></div>
							))}
						</div>

						{agents.length > 3 && (
							<div class="rung__edge" aria-hidden="true">
								<span class="rung__edge-chevron">›</span>
							</div>
						)}

						{agents.length === 1 && (
							<aside class="rung__solo" aria-hidden="true">
								<SumiInk variant="corner" className="rung__solo-ink" />
								<p class="mono rung__solo-cap">only one in tier · capability: <code>{TIER_META[tier].cap}</code></p>
							</aside>
						)}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<script>
	(() => {
		const rows = Array.from(
			document.querySelectorAll<HTMLElement>('.rung__cards[data-overflow="true"]'),
		);
		if (!rows.length) return;

		for (const track of rows) {
			// Mouse drag-to-scroll. The grab/grabbing cursor advertises this; native
			// overflow-x already covers touch + trackpad, this adds parity for mouse.
			let dragging = false;
			let dragStartX = 0;
			let dragStartScroll = 0;

			track.addEventListener("mousedown", (e) => {
				const me = e as MouseEvent;
				if (me.button !== 0) return;
				dragging = true;
				dragStartX = me.pageX;
				dragStartScroll = track.scrollLeft;
				track.classList.add("is-dragging");
			});
			window.addEventListener("mousemove", (e) => {
				if (!dragging) return;
				const me = e as MouseEvent;
				track.scrollLeft = dragStartScroll - (me.pageX - dragStartX);
			});
			const endDrag = () => {
				if (!dragging) return;
				dragging = false;
				track.classList.remove("is-dragging");
			};
			window.addEventListener("mouseup", endDrag);
			window.addEventListener("blur", endDrag);

			// Keyboard: focusable row, arrow/Home/End advance one card at a time.
			track.tabIndex = 0;
			track.addEventListener("keydown", (e) => {
				const ke = e as KeyboardEvent;
				if (ke.key !== "ArrowLeft" && ke.key !== "ArrowRight" && ke.key !== "Home" && ke.key !== "End") return;
				e.preventDefault();
				const cards = Array.from(track.querySelectorAll<HTMLElement>(".rung__card-wrap"));
				if (!cards.length) return;
				const trackLeft = track.getBoundingClientRect().left;
				// Offset of each card from the track's scroll origin. Card nearest the
				// left edge is the current anchor.
				const offsets = cards.map((c) => track.scrollLeft + (c.getBoundingClientRect().left - trackLeft));
				let current = 0;
				let bestDist = Infinity;
				offsets.forEach((off, i) => {
					const d = Math.abs(off - track.scrollLeft);
					if (d < bestDist) {
						bestDist = d;
						current = i;
					}
				});
				let target = current;
				if (ke.key === "ArrowLeft") target = Math.max(0, current - 1);
				else if (ke.key === "ArrowRight") target = Math.min(cards.length - 1, current + 1);
				else if (ke.key === "Home") target = 0;
				else if (ke.key === "End") target = cards.length - 1;
				track.scrollTo({ left: offsets[target], behavior: "smooth" });
			});
		}
	})();
</script>

<style>
	.agents__lede {
		color: var(--text-quiet);
		max-width: 64ch;
		margin-bottom: var(--space-6);
	}

	.ladder {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.ladder__rung {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4);
		padding: var(--space-6) 0;
		border-top: 1px solid var(--rule);
	}
	/* First rung sits directly under the SumiInk brushstroke — a hairline
	   here would duplicate the divider read. Brushstroke handles the intro;
	   hairlines resume between subsequent rungs. */
	.ladder__rung:first-child { border-top: 0; padding-top: var(--space-4); }
	.ladder__rung:last-child { padding-bottom: 0; }

	@media (min-width: 920px) {
		.ladder__rung {
			grid-template-columns: 220px 1fr;
			gap: var(--space-7);
			padding: var(--space-7) 0;
		}
	}

	/* Tier label rail */
	.rung__label {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.rung__num {
		font-size: var(--type-tiny);
		letter-spacing: 0.18em;
		color: var(--text-distant);
		text-transform: uppercase;
		margin: 0;
	}
	.rung__name {
		font-size: var(--type-h3);
		margin: 0;
		color: var(--washi);
	}
	.rung__note {
		font-family: var(--font-serif);
		font-size: var(--type-small);
		color: var(--text-quiet);
		margin: 0;
		max-width: 32ch;
	}
	.rung__count {
		font-size: var(--type-tiny);
		color: var(--text-distant);
		margin: var(--space-2) 0 0;
		display: inline-flex;
		align-items: baseline;
		gap: var(--space-2);
		padding-top: var(--space-2);
		border-top: 1px solid var(--rule);
		max-width: max-content;
	}
	.rung__count-num {
		color: var(--sage);
		font-size: var(--type-small);
	}

	/* Right area — relative for the floating chevron affordance */
	.rung__cells {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4);
		position: relative;
	}
	/* Uniform card sizing across all tiers: fixed-width flex track.
	   Tiers with > 3 agents become a minimalistic horizontal slider:
	   native scroll-snap + visible peek of the next card + soft fade +
	   pulsing chevron + cursor:grab. */
	.rung__cards {
		display: flex;
		gap: var(--space-4);
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		scroll-padding-left: 0;
		padding-bottom: var(--space-2);
		-webkit-overflow-scrolling: touch;

		/* Neutral, always-visible scrollbar — matches the pipeline (.emaki) and
		   sibling-card scrollers for a consistent read across the page. */
		scrollbar-width: thin;
		scrollbar-color: var(--rule-strong) transparent;
	}
	.rung__cards[data-overflow="true"] { outline: none; }
	.rung__cards[data-overflow="true"]:focus-visible {
		outline: 1px solid var(--sage);
		outline-offset: 4px;
	}

	.rung__cards[data-overflow="true"] {
		cursor: grab;
		mask-image: linear-gradient(to right, black calc(100% - 56px), transparent 100%);
		-webkit-mask-image: linear-gradient(to right, black calc(100% - 56px), transparent 100%);
	}
	.rung__cards[data-overflow="true"]:active { cursor: grabbing; }
	/* During an active mouse drag, suppress snap (it fights the drag) and text
	   selection, and pin the grabbing cursor even if the pointer leaves the row. */
	.rung__cards.is-dragging {
		cursor: grabbing;
		scroll-snap-type: none;
		user-select: none;
	}

	.rung__cards::-webkit-scrollbar { height: 6px; }
	.rung__cards::-webkit-scrollbar-track { background: transparent; }
	.rung__cards::-webkit-scrollbar-thumb {
		background: var(--rule-strong);
		border-radius: var(--radius-md);
	}

	/* Card width: 224px gives the locator (4 cards) a real ~64px peek
	   of the 4th card past the cells column edge — enough to read its
	   name and ×N badge before any scroll. */
	.rung__card-wrap {
		flex: 0 0 224px;
		display: flex;
		min-width: 0;
		scroll-snap-align: start;
	}
	.rung__card-wrap > .agent { flex: 1; min-width: 0; }

	/* Right-edge chevron: floats over the faded peek, vertically centered.
	   Subtle pulse animation (translate 6px right) draws the eye to the
	   action zone without violating wabi-sabi restraint. */
	.rung__edge {
		position: absolute;
		top: 0;
		right: 0;
		bottom: var(--space-2); /* clear the scrollbar */
		width: 32px;
		display: flex;
		align-items: center;
		justify-content: center;
		pointer-events: none;
		z-index: 2;
	}
	.rung__edge-chevron {
		font-family: var(--font-mono);
		font-size: 32px;
		line-height: 1;
		color: var(--sage);
		opacity: 0.75;
		animation: rung-chevron-pulse 2.4s var(--ease-ink) infinite;
	}
	@keyframes rung-chevron-pulse {
		0%, 100% { transform: translateX(0); opacity: 0.55; }
		50%      { transform: translateX(6px); opacity: 0.95; }
	}
	@media (prefers-reduced-motion: reduce) {
		.rung__edge-chevron { animation: none; opacity: 0.85; }
	}

	/* Rail pager: lives directly under the agent count, in the user's
	   reading flow. Film-strip bars + mono caption that names the count
	   of hidden cards explicitly. */
	.rung__pager {
		margin-top: var(--space-3);
		padding-top: var(--space-3);
		border-top: 1px solid var(--rule);
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.rung__pager-bars {
		display: flex;
		gap: 4px;
		align-items: center;
	}
	.rung__pager-bar {
		display: inline-block;
		width: 16px;
		height: 3px;
		background: var(--rule-strong);
		border-radius: var(--radius-xs);
	}
	.rung__pager-bar.is-visible {
		background: var(--sage);
	}
	.rung__pager-cap {
		font-size: var(--type-tiny);
		color: var(--text-distant);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		margin: 0;
		display: flex;
		align-items: baseline;
		gap: var(--space-1);
	}
	.rung__pager-arrow {
		color: var(--sage);
		font-size: var(--type-small);
	}
	.rung__pager-num {
		color: var(--ochre);
		font-size: var(--type-small);
	}

	/* Solo-tier composition: ink mark + watermark caption */
	.ladder__rung[data-solo="true"] .rung__cards {
		overflow: visible;
		scroll-snap-type: none;
		padding-bottom: 0;
	}
	.rung__solo {
		position: relative;
		min-height: 80px;
		display: flex;
		align-items: end;
		justify-content: end;
		padding: var(--space-4) var(--space-3) 0;
	}
	.rung__solo-ink {
		position: absolute;
		top: 0;
		right: 0;
		width: 160px;
		height: auto;
		color: var(--ochre);
		opacity: 0.55;
		pointer-events: none;
	}
	.rung__solo-cap {
		font-size: var(--type-tiny);
		color: var(--text-distant);
		margin: 0;
		text-align: right;
		max-width: 28ch;
		position: relative;
		z-index: 1;
	}
	.rung__solo-cap code {
		color: var(--ochre);
		background: transparent;
	}

	/* On wider screens, lay solo card and ink-mark side-by-side */
	@media (min-width: 720px) {
		.ladder__rung[data-solo="true"] .rung__cells {
			grid-template-columns: 224px 1fr;
			align-items: stretch;
			gap: var(--space-6);
		}
		.rung__solo { min-height: 100%; }
	}
</style>
