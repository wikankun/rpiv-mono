---
import { getAgentsByTier, type AgentEntry, type CapabilityTier } from "../lib/agents";
import AgentCard from "./AgentCard.astro";
import SumiInk from "./SumiInk.astro";

const groups = await getAgentsByTier();
// Derived, not hardcoded — TIER_BY_NAME and the on-disk specs both move.
const agentCount = groups.reduce((n, g) => n + g.agents.length, 0);
const tierCount = groups.filter((g) => g.agents.length > 0).length;

const TIER_META: Record<CapabilityTier, { label: string; note: string; cap: string }> = {
	locator:    { label: "Locators",                note: "where. No file content access.",                                       cap: "find" },
	analyzer:   { label: "Analyzers",               note: "how. Reads file content, plus git history via precedent-locator.",     cap: "read" },
	external:   { label: "External agents",         note: "+ web search and fetch",                                               cap: "web"  },
	specialist: { label: "Code-review specialists", note: "Pipe-delimited findings, never prose.",                                cap: "rows" },
};

// Tool-chip dedupe: each tier shares a baseline allowlist (locators read
// nothing, analyzers add read, etc.). Show that baseline once at the tier
// label; cards surface only what they add on top, so the repeated
// read/grep/find/ls noise collapses and the rare extra (claim-verifier's
// bash, the researcher's web tools) stands out.
const toolsOf = (a: AgentEntry): string[] =>
	a.data.tools?.split(",").map((t) => t.trim()).filter(Boolean) ?? [];
const labelTool = (t: string): string => t.replace(/^ext:[^/]+\//, "");
function sharedTools(agents: AgentEntry[]): string[] {
	if (!agents.length) return [];
	return toolsOf(agents[0]).filter((t) => agents.every((a) => toolsOf(a).includes(t)));
}
---

<section id="agents">
	<div class="container">
		<p class="kicker">§ subagents · {agentCount} across {tierCount} tiers</p>
		<h2>Specialists, not generalists.</h2>
		<p class="agents__lede">
			Skills do orchestration. Agents do one narrow thing. Each is isolated,
			each is read-only, each tier is defined by its tool allowlist. Code-review&rsquo;s
			specialists return rows of pipe-delimited findings, never prose, so
			verification stays mechanical.
		</p>

		<SumiInk variant="divider" />

		<div class="ladder" role="list">
			{groups.map(({ tier, agents }, tierIdx) => agents.length > 0 && (
				<div class="ladder__rung" role="listitem" data-solo={agents.length === 1 ? "true" : "false"}>
					<div class="rung__label">
						<p class="rung__num mono">tier {String(tierIdx + 1).padStart(2, "0")}</p>
						<h3 class="mono rung__name">{TIER_META[tier].label}</h3>
						<p class="rung__note">{TIER_META[tier].note}</p>
						<p class="rung__count mono">
							<span class="rung__count-num">{agents.length}</span>
							<span class="rung__count-word">{agents.length === 1 ? "agent" : "agents"}</span>
						</p>

						{sharedTools(agents).length > 0 && (
							<div class="rung__tools">
								<p class="mono rung__tools-label">shared allowlist</p>
								<ul class="rung__tools-list" aria-label="tools every agent in this tier may call">
									{sharedTools(agents).map((t) => (
										<li class="chip chip--sage rung__tool">{labelTool(t)}</li>
									))}
								</ul>
							</div>
						)}
					</div>

					<div class="rung__cells">
						<div class="rung__cards" role="list">
							{agents.map((agent) => (
								<div role="listitem" class="rung__card-wrap">
									<AgentCard agent={agent} sharedTools={sharedTools(agents)} />
								</div>
							))}
						</div>

						{agents.length === 1 && (
							<aside class="rung__solo" aria-hidden="true">
								<SumiInk variant="corner" className="rung__solo-ink" />
								<p class="mono rung__solo-cap">only one in tier · capability: <code>{TIER_META[tier].cap}</code></p>
							</aside>
						)}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.agents__lede {
		color: var(--text-quiet);
		max-width: 64ch;
		margin-bottom: var(--space-6);
	}

	.ladder {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.ladder__rung {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4);
		padding: var(--space-6) 0;
		border-top: 1px solid var(--rule);
	}
	/* First rung sits directly under the SumiInk brushstroke — a hairline
	   here would duplicate the divider read. Brushstroke handles the intro;
	   hairlines resume between subsequent rungs. */
	.ladder__rung:first-child { border-top: 0; padding-top: var(--space-4); }
	.ladder__rung:last-child { padding-bottom: 0; }

	@media (min-width: 920px) {
		.ladder__rung {
			grid-template-columns: 220px 1fr;
			gap: var(--space-7);
			padding: var(--space-7) 0;
		}
	}

	/* Tier label rail */
	.rung__label {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.rung__num {
		font-size: var(--type-tiny);
		letter-spacing: 0.18em;
		color: var(--text-distant);
		text-transform: uppercase;
		margin: 0;
	}
	.rung__name {
		font-size: var(--type-h3);
		margin: 0;
		color: var(--washi);
	}
	.rung__note {
		font-family: var(--font-serif);
		font-size: var(--type-small);
		color: var(--text-quiet);
		margin: 0;
		max-width: 32ch;
	}
	.rung__count {
		font-size: var(--type-tiny);
		color: var(--text-distant);
		margin: var(--space-2) 0 0;
		display: inline-flex;
		align-items: baseline;
		gap: var(--space-2);
		padding-top: var(--space-2);
		border-top: 1px solid var(--rule);
		max-width: max-content;
	}
	.rung__count-num {
		color: var(--sage);
		font-size: var(--type-small);
	}

	/* Shared allowlist — the tier's common tools, named once here so the cards
	   don't repeat them. The card-level extras (+bash etc.) read against it. */
	.rung__tools {
		margin-top: var(--space-3);
		padding-top: var(--space-3);
		border-top: 1px solid var(--rule);
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.rung__tools-label {
		font-size: var(--type-tiny);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-distant);
		margin: 0;
	}
	.rung__tools-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	/* Right area */
	.rung__cells {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4);
		position: relative;
	}
	/* Wrapped grid: every agent in the tier is visible at once, no scroller.
	   auto-fill keeps a consistent card width and flows onto as many rows as
	   the tier needs. */
	.rung__cards {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
		gap: var(--space-4);
	}
	.rung__card-wrap {
		display: flex;
		min-width: 0;
	}
	.rung__card-wrap > .agent { flex: 1; min-width: 0; }

	/* Solo-tier composition: ink mark + watermark caption */
	.rung__solo {
		position: relative;
		min-height: 80px;
		display: flex;
		align-items: end;
		justify-content: end;
		padding: var(--space-4) var(--space-3) 0;
	}
	.rung__solo-ink {
		position: absolute;
		top: 0;
		right: 0;
		width: 160px;
		height: auto;
		color: var(--ochre);
		opacity: 0.55;
		pointer-events: none;
	}
	.rung__solo-cap {
		font-size: var(--type-tiny);
		color: var(--text-distant);
		margin: 0;
		text-align: right;
		max-width: 28ch;
		position: relative;
		z-index: 1;
	}
	.rung__solo-cap code {
		color: var(--ochre);
		background: transparent;
	}

	/* On wider screens, lay solo card and ink-mark side-by-side */
	@media (min-width: 720px) {
		.ladder__rung[data-solo="true"] .rung__cells {
			grid-template-columns: 224px 1fr;
			align-items: stretch;
			gap: var(--space-6);
		}
		.rung__solo { min-height: 100%; }
	}
</style>
