---
// §7 — the cost story. The pipeline is viable on affordable open-weight
// models today, with per-stage model control so frontier tokens are spent
// only where they earn their keep. The gain/cost ledger states the residual
// gap honestly — the answer line points at the roadmap, which is exactly the
// work that closes it.
const OPEN_MODELS = ["GLM-5.1", "Kimi K2.5", "MiMo-V2-Pro"];
---

<section id="models">
	<div class="container">
		<p class="kicker">§ models · no frontier budget required</p>
		<h2>Built to run on affordable models.</h2>
		<p class="models__lede">
			The pipeline produces genuinely good results on open-weight models at a
			fraction of frontier token prices, and it is honest about the
			residual gap.
		</p>

		<p class="models__chips">
			{OPEN_MODELS.map((m) => <span class="chip chip--sage">{m}</span>)}
			<span class="models__chipNote">… or Claude, GPT, Gemini: bring your own key.</span>
		</p>

		<div class="models__control">
			<pre class="models__pre"><code>/rpiv-models</code></pre>
			<p class="models__controlNote">
				Per-skill and per-stage model + reasoning-effort overrides, cascading
				from defaults down to a single workflow stage. Run the chain on an
				affordable model and escalate just the review and judge stages to a
				frontier one, spending the expensive tokens only where they earn
				their keep.
			</p>
		</div>

		<div class="models-trade">
			<div class="models-trade__col models-trade__col--gain">
				<p class="mono models-trade__label">gain</p>
				<ul class="models-trade__list">
					<li>runs end to end on open-weight models, at roughly a third of frontier output pricing</li>
					<li>same pipeline, same contracts, same audit at any price point</li>
					<li>per-stage escalation: frontier judgement without frontier-priced drafting</li>
				</ul>
			</div>
			<div class="models-trade__col models-trade__col--cost">
				<p class="mono models-trade__label">cost</p>
				<ul class="models-trade__list">
					<li>not yet at parity with frontier on the same task: more mistakes, longer runs</li>
					<li class="models-trade__answer">closing that gap is the active <a href="#roadmap">roadmap</a>: fresh-context verification first, frontier escalation only where it pays</li>
				</ul>
			</div>
		</div>
	</div>
</section>

<style>
	.models__lede {
		font-family: var(--font-serif);
		max-width: 60ch;
		color: var(--text-quiet);
		font-size: var(--type-lead);
		line-height: var(--leading-body);
		margin: var(--space-4) 0 var(--space-6);
		text-wrap: pretty;
	}

	.models__chips {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin: 0 0 var(--space-7);
	}
	.models__chipNote {
		font-family: var(--font-serif);
		font-size: var(--type-small);
		color: var(--text-distant);
		font-style: italic;
	}

	.models__control {
		display: grid;
		grid-template-columns: minmax(220px, 300px) 1fr;
		gap: var(--space-5);
		align-items: start;
		max-width: 920px;
		margin-bottom: var(--space-7);
	}
	.models__pre {
		margin: 0;
		border-left-color: var(--ochre);
	}
	.models__controlNote {
		font-family: var(--font-serif);
		font-size: var(--type-small);
		line-height: var(--leading-relaxed);
		color: var(--text-quiet);
		margin: 0;
		text-wrap: pretty;
	}

	/* ── Ledger — same idiom as §why / §thesis trades ── */
	.models-trade {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-6);
		max-width: 920px;
		border-top: 1px solid var(--rule-strong);
		padding-top: var(--space-5);
	}
	.models-trade__label {
		font-size: var(--type-tiny);
		text-transform: uppercase;
		letter-spacing: 0.16em;
		margin: 0 0 var(--space-3);
	}
	/* gold marks the advantages, grey the costs — same semantics as the
	   thesis ledger */
	.models-trade__col--gain .models-trade__label { color: var(--ochre); }
	.models-trade__col--cost .models-trade__label { color: var(--text-distant); }
	.models-trade__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.models-trade__list li {
		font-family: var(--font-serif);
		font-size: var(--type-small);
		line-height: var(--leading-snug);
		color: var(--text-quiet);
		padding-left: var(--space-4);
		position: relative;
	}
	.models-trade__col--gain .models-trade__list li::before {
		content: "+";
		position: absolute;
		left: 0;
		color: var(--ochre);
		font-family: var(--font-mono);
	}
	.models-trade__col--cost .models-trade__list li::before {
		content: "−";
		position: absolute;
		left: 0;
		color: var(--text-distant);
		font-family: var(--font-mono);
	}
	.models-trade__answer { color: var(--text-distant); font-style: italic; }
	.models-trade__col--cost .models-trade__answer::before { content: "↳"; }

	@media (max-width: 720px) {
		.models__control { grid-template-columns: 1fr; gap: var(--space-3); }
		.models-trade { grid-template-columns: 1fr; gap: var(--space-5); }
	}
</style>
