---
const STEPS = [
	{
		title: "Runs only when it's safe",
		body: "In a headless or automated session it notifies and exits: nothing is read, nothing is installed.",
	},
	{
		title: "Works out what's needed",
		body: "Reads your Pi settings and figures out which sibling extensions are missing and which stale entries should go. If settings can't be read, it backs off instead of guessing.",
	},
	{
		title: "Stops if there's nothing to do",
		body: "Already installed and clean? It says so and returns: no prompt, no changes.",
	},
	{
		title: "Asks once",
		body: "Shows a single preview of exactly what it will install and what it will remove, then asks to proceed. Cancel leaves everything untouched.",
	},
	{
		title: "Prunes the stale entries",
		body: "Removes the outdated entries from your settings. A write error is reported, never fatal.",
	},
	{
		title: "Installs one at a time",
		body: "Each missing sibling installs on its own, with a time limit so one slow or stuck install can't stall the rest.",
	},
	{
		title: "Tells you what changed",
		body: "Lists what installed and what failed, and asks you to restart your Pi session only when something actually changed.",
	},
];
---

<section id="setup" aria-labelledby="setup-title">
	<div class="container setup">
		<p class="kicker">§ setup · /rpiv-setup</p>
		<h2 id="setup-title">Scan, confirm, install. One prompt.</h2>

		<ol class="trace">
			{STEPS.map((step, i) => (
				<li class="trace__item">
					<div class="trace__rail" aria-hidden="true">
						<svg class="trace__node" viewBox="0 0 40 40">
							<circle cx="20" cy="20" r="14" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.45" />
							<circle cx="20" cy="20" r="10.5" fill="var(--ink-raised)" stroke="currentColor" stroke-width="1.1" />
							<circle cx="20" cy="20" r="10.5" fill="currentColor" opacity="0.16" />
							<text x="20" y="23.5" text-anchor="middle" class="trace__nodeNum">{String(i + 1).padStart(2, "0")}</text>
						</svg>
					</div>
					<div class="trace__content">
						<h3 class="mono trace__title">{step.title}</h3>
						<p class="trace__body">{step.body}</p>
					</div>
				</li>
			))}
		</ol>
	</div>
</section>

<style>
	#setup h2 {
		max-width: 56ch;
		margin-bottom: var(--space-7);
	}

	.trace {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.trace__item {
		display: grid;
		grid-template-columns: 56px 1fr;
		gap: var(--space-5);
		padding-bottom: var(--space-6);
		position: relative;
	}
	.trace__item:last-child { padding-bottom: 0; }

	.trace__rail {
		position: relative;
		display: flex;
		justify-content: center;
		color: var(--ochre);
	}
	.trace__rail::before {
		content: "";
		position: absolute;
		top: 42px;
		bottom: -12px;
		left: 50%;
		width: 1px;
		background: linear-gradient(
			to bottom,
			var(--kuro) 0%,
			var(--rule-strong) 70%,
			transparent 100%
		);
		transform: translateX(-0.5px);
		opacity: 0.8;
	}
	.trace__item:last-child .trace__rail::before { display: none; }

	.trace__node {
		width: 44px;
		height: 44px;
		flex-shrink: 0;
		position: relative;
		z-index: 1;
		color: var(--ochre);
	}
	.trace__nodeNum {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.06em;
		fill: var(--washi);
	}

	.trace__content { padding-top: 6px; }
	.trace__title {
		margin: 0 0 var(--space-2);
		font-size: var(--type-h3);
	}
	.trace__body {
		font-family: var(--font-serif);
		color: var(--text);
		font-size: var(--type-small);
		margin: 0;
		max-width: 64ch;
	}

	@media (max-width: 720px) {
		.trace__item {
			grid-template-columns: 40px 1fr;
			gap: var(--space-3);
		}
		.trace__node { width: 36px; height: 36px; }
		.trace__rail::before { top: 36px; }
	}
</style>
