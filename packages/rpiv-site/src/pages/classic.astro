---
// Archived landing — the original mechanism-first tour ("workflow runner"),
// kept reachable for comparison after the thesis-first landing was promoted
// to /. Unlisted: noindex + excluded from the sitemap in astro.config.mjs.
// Delete this page when the comparison has served its purpose.
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import ScrollIndicator from "../components/ScrollIndicator.astro";
import Hero from "../components/Hero.astro";
import WhyWorkflow from "../components/WhyWorkflow.astro";
import WorkflowCatalog from "../components/WorkflowCatalog.astro";
import RunAnatomy from "../components/RunAnatomy.astro";
import StageSkills from "../components/StageSkills.astro";
import AroundSkills from "../components/AroundSkills.astro";
import Guidance from "../components/Guidance.astro";
import AgentGrid from "../components/AgentGrid.astro";
import SiblingGrid from "../components/SiblingGrid.astro";
import Install from "../components/Install.astro";
import SetupTrace from "../components/SetupTrace.astro";

const NAV_LINKS = [
	{ id: "catalog", label: "flows" },
	{ id: "anatomy", label: "run" },
	{ id: "skills", label: "skills" },
	{ id: "around", label: "around" },
	{ id: "guidance", label: "guidance" },
	{ id: "agents", label: "agents" },
];

const SECTIONS = [
	{ id: "top", label: "intro" },
	{ id: "why", label: "shift" },
	{ id: "catalog", label: "flows" },
	{ id: "anatomy", label: "run" },
	{ id: "skills", label: "skills" },
	{ id: "around", label: "around" },
	{ id: "guidance", label: "guidance" },
	{ id: "agents", label: "agents" },
	{ id: "siblings", label: "siblings" },
	{ id: "install", label: "install" },
	{ id: "setup", label: "setup" },
];
---

<Base
	title="rpiv-pi · workflow runner for the Pi coding agent"
	description="Six workflows that chain Pi skills into one command. /wf turns a task into research, a plan, an implementation, a review, and a commit, end to end."
	noindex
>
	<Nav links={NAV_LINKS} />
	<ScrollIndicator sections={SECTIONS} />
	<main class="landing">
		<Hero />
		<WhyWorkflow />
		<WorkflowCatalog />
		<RunAnatomy />
		<StageSkills />
		<AroundSkills />
		<Guidance />
		<AgentGrid />
		<SiblingGrid />
		<Install />
		<SetupTrace />
	</main>
</Base>
