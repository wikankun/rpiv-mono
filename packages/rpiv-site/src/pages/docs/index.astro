---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import SumiInk from "../../components/SumiInk.astro";
import { getDocsBySection, SECTION_LABELS, type DocSection } from "../../lib/docs";

const sections = await getDocsBySection();

// Curated copy per section. Lives here as visitor copy alongside the layout
// that needs it; the docs collection itself doesn't carry section blurbs.
const SECTION_BLURBS: Record<DocSection, string> = {
	"getting-started": "Install rpiv-pi, run your first pipeline session, and let the skill chain take it from there. Three steps to shipped code.",
	guides: "Task-oriented walkthroughs. Real flows from a real session, with the artifacts each step leaves behind.",
	explanation: "The why behind rpiv-pi: pipeline philosophy, architecture choices, and the editorial flow that ties it together.",
	reference: "Every skill and every subagent at a glance. Open this when something is named in conversation and you want the source.",
};

const sectionsWithEntries = sections.filter(({ entries }) => entries.length > 0);
---

<Base
	title="Docs · rpiv-pi"
	description="Documentation for rpiv-pi. Install, run your first pipeline, browse the skill and agent reference."
>
	<Nav />
	<main>
		{/* ── HERO ────────────────────────────────────────────── */}
		<section class="docs-hero">
			<SumiInk variant="backdrop" />
			<div class="container docs-hero__inner">
				<p class="kicker docs-hero__kicker">§ rpiv-pi · documentation</p>
				<h1 class="docs-hero__title">Read the manual.</h1>
				<p class="docs-hero__lede">
					Three steps. One restart. The rest is reference.
				</p>
			</div>
		</section>

		{/* ── QUICK START ─────────────────────────────────────── */}
		<section class="docs-quickstart">
			<div class="container">
				<p class="kicker docs-quickstart__kicker">quick start</p>
				<div class="card docs-quickstart__card">
					<ol class="docs-quickstart__steps">
						<li class="docs-quickstart__step">
							<span class="docs-quickstart__num mono">01</span>
							<div class="docs-quickstart__body">
								<p class="docs-quickstart__label">install · shell</p>
								<code class="docs-quickstart__code">pi install npm:@juicesharp/rpiv-pi</code>
							</div>
						</li>
						<li class="docs-quickstart__step">
							<span class="docs-quickstart__num mono">02</span>
							<div class="docs-quickstart__body">
								<p class="docs-quickstart__label">setup · inside pi</p>
								<code class="docs-quickstart__code">/rpiv-setup</code>
								<p class="docs-quickstart__hint">
									Previews missing sibling plugins. One confirm to apply.
								</p>
							</div>
						</li>
						<li class="docs-quickstart__step">
							<span class="docs-quickstart__num mono">03</span>
							<div class="docs-quickstart__body">
								<p class="docs-quickstart__label">restart pi</p>
								<p class="docs-quickstart__hint">
									Quit and relaunch so the freshly-installed siblings load.
								</p>
							</div>
						</li>
					</ol>
					<a href="/docs/getting-started" class="docs-quickstart__cta mono">
						Full install walkthrough&nbsp;&nbsp;→
					</a>
				</div>
			</div>
		</section>

		{/* ── SECTION GRID ────────────────────────────────────── */}
		<section class="docs-grid-section">
			<div class="container">
				<p class="kicker">browse the docs</p>
				<div class="docs-grid">
					{sectionsWithEntries.map(({ section, entries }, i) => (
						<article
							class:list={["docs-grid__card", `docs-grid__card--${section}`]}
							style={`--card-i: ${i}`}
						>
							{section === "getting-started" && (
								<SumiInk variant="corner" className="docs-grid__sumi" />
							)}
							<p class="kicker docs-grid__kicker">{SECTION_LABELS[section]}</p>
							<h2 class="docs-grid__title">
								<a href={`/docs/${entries[0].id}`}>{entries[0].data.title}</a>
							</h2>
							<p class="docs-grid__blurb">{SECTION_BLURBS[section]}</p>
							{entries.length > 1 && (
								<ul class="docs-grid__list">
									{entries.slice(1).map((entry) => (
										<li>
											<a href={`/docs/${entry.id}`} class="mono docs-grid__link">
												{entry.data.title}
											</a>
										</li>
									))}
								</ul>
							)}
						</article>
					))}
					<article
						class="docs-grid__card docs-grid__card--reference"
						style={`--card-i: ${sectionsWithEntries.length}`}
					>
						<p class="kicker docs-grid__kicker">Reference</p>
						<h2 class="docs-grid__title">Skills &amp; Agents</h2>
						<p class="docs-grid__blurb">{SECTION_BLURBS.reference}</p>
						<ul class="docs-grid__list docs-grid__list--inline">
							<li>
								<a href="/docs/reference/skills" class="mono docs-grid__link">
									Skills reference
								</a>
							</li>
							<li>
								<a href="/docs/reference/agents" class="mono docs-grid__link">
									Agents reference
								</a>
							</li>
						</ul>
					</article>
				</div>
			</div>
		</section>

		{/* ── PATH CHIPS ──────────────────────────────────────── */}
		<section class="docs-paths">
			<div class="container">
				<p class="kicker">i want to…</p>
				<ul class="docs-paths__chips">
					<li><a class="chip chip--sage" href="/docs/getting-started">install rpiv-pi</a></li>
					<li><a class="chip chip--sage" href="/docs/guides/pick-a-path">pick a workflow</a></li>
					<li><a class="chip chip--ochre" href="/docs/reference/skills">browse all skills</a></li>
					<li><a class="chip chip--ochre" href="/docs/reference/agents">browse all agents</a></li>
					<li><a class="chip chip--muted" href="/docs/guides/first-skill-chain">walk the chain</a></li>
				</ul>
			</div>
		</section>
	</main>
</Base>

<style>
	/* ── HERO ─────────────────────────────────────────────────────── */
	.docs-hero {
		position: relative;
		overflow: hidden;
		padding: var(--space-9) 0 var(--space-7);
	}
	.docs-hero__inner {
		position: relative;
		z-index: 1;
	}
	.docs-hero__title {
		font-size: var(--type-h2);
		line-height: var(--leading-tight);
		margin-bottom: var(--space-5);
		max-width: 20ch;
	}
	.docs-hero__lede {
		font-family: var(--font-serif);
		font-size: var(--type-lead);
		line-height: var(--leading-body);
		color: var(--text-quiet);
		max-width: 56ch;
		margin: 0;
	}

	/* ── QUICK START ──────────────────────────────────────────────── */
	.docs-quickstart {
		padding: var(--space-6) 0 var(--space-7);
	}
	.docs-quickstart__kicker {
		color: var(--ochre);
	}
	.docs-quickstart__card {
		max-width: 720px;
	}
	.docs-quickstart__steps {
		list-style: none;
		padding: 0;
		margin: 0 0 var(--space-5);
		display: grid;
		gap: var(--space-5);
	}
	.docs-quickstart__step {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-4);
		align-items: baseline;
	}
	.docs-quickstart__num {
		font-size: var(--type-small);
		color: var(--ochre);
		letter-spacing: 0.04em;
	}
	.docs-quickstart__body {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		min-width: 0;
	}
	.docs-quickstart__label {
		font-family: var(--font-mono);
		font-size: var(--type-tiny);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--text-distant);
		margin: 0;
	}
	.docs-quickstart__code {
		font-family: var(--font-mono);
		font-size: var(--type-small);
		color: var(--washi);
		background: var(--ink-muted);
		padding: var(--space-2) var(--space-3);
		border-radius: var(--radius-sm);
		border-left: 1px solid var(--sage-deep);
		align-self: start;
		max-width: 100%;
		overflow-x: auto;
	}
	.docs-quickstart__hint {
		font-family: var(--font-serif);
		font-size: var(--type-small);
		color: var(--text-quiet);
		margin: 0;
		line-height: var(--leading-relaxed);
		max-width: none;
	}
	.docs-quickstart__hint .mono {
		font-size: var(--type-tiny);
		color: var(--text-distant);
	}
	.docs-quickstart__cta {
		display: inline-block;
		font-size: var(--type-small);
		color: var(--ochre);
		border-bottom-color: var(--kuro);
	}

	/* ── SECTION GRID ─────────────────────────────────────────────── */
	.docs-grid-section {
		padding: var(--space-7) 0;
	}
	.docs-grid {
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		gap: var(--space-5);
		margin-top: var(--space-5);
	}
	.docs-grid__card {
		position: relative;
		overflow: hidden;
		background: var(--ink-raised);
		border-top: 1px solid var(--rule);
		border-left: 1px solid var(--rule);
		border-right: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule-strong);
		padding: var(--space-6) var(--space-5);
		transition:
			border-bottom-color var(--dur-ink) var(--ease-ink),
			transform var(--dur-ink) var(--ease-ink);
	}
	.docs-grid__card:hover {
		border-bottom-color: var(--ochre);
	}
	/* Asymmetric editorial grid: Getting Started takes the lede width,
	   Guides + Reference share the secondary rail. */
	.docs-grid__card--getting-started {
		grid-column: span 7;
	}
	.docs-grid__card--guides {
		grid-column: span 5;
	}
	.docs-grid__card--explanation {
		grid-column: span 6;
	}
	.docs-grid__card--reference {
		grid-column: span 12;
	}
	.docs-grid__sumi {
		opacity: 0.4;
		width: 160px;
	}
	.docs-grid__kicker {
		color: var(--sage);
		margin-bottom: var(--space-3);
	}
	.docs-grid__title {
		font-size: var(--type-h-hero);
		line-height: var(--leading-snug);
		margin-bottom: var(--space-3);
	}
	.docs-grid__title a {
		color: var(--washi);
		border-bottom: none;
		transition: color var(--dur-ink) var(--ease-ink);
	}
	.docs-grid__title a:hover {
		color: var(--sage);
	}
	.docs-grid__blurb {
		font-family: var(--font-serif);
		font-size: var(--type-base);
		color: var(--text-quiet);
		line-height: var(--leading-relaxed);
		max-width: 52ch;
		margin: 0 0 var(--space-4);
	}
	.docs-grid__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		border-top: 1px solid var(--rule);
		padding-top: var(--space-4);
	}
	.docs-grid__list--inline {
		flex-direction: row;
		flex-wrap: wrap;
		gap: var(--space-5);
	}
	.docs-grid__link {
		font-size: var(--type-small);
		color: var(--text-quiet);
		border-bottom: none;
		transition: color var(--dur-ink) var(--ease-ink);
	}
	.docs-grid__link::before {
		content: "→\00a0\00a0";
		color: var(--text-distant);
	}
	.docs-grid__link:hover {
		color: var(--sage);
	}

	@media (max-width: 720px) {
		.docs-grid {
			grid-template-columns: 1fr;
		}
		.docs-grid__card--getting-started,
		.docs-grid__card--guides,
		.docs-grid__card--explanation,
		.docs-grid__card--reference {
			grid-column: span 1;
		}
		.docs-grid__title {
			font-size: var(--type-h3);
		}
	}

	/* ── PATH CHIPS ───────────────────────────────────────────────── */
	.docs-paths {
		padding: var(--space-6) 0 var(--space-9);
	}
	.docs-paths__chips {
		list-style: none;
		padding: 0;
		margin: var(--space-4) 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}
	.docs-paths__chips .chip {
		transition:
			color var(--dur-ink) var(--ease-ink),
			border-color var(--dur-ink) var(--ease-ink);
	}
	.docs-paths__chips .chip:hover {
		color: var(--washi);
		border-color: var(--washi-soft);
	}

	/* ── STAGGERED REVEAL ─────────────────────────────────────────── */
	@keyframes docs-rise {
		from { opacity: 0; transform: translateY(8px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	.docs-hero__kicker,
	.docs-hero__title,
	.docs-hero__lede,
	.docs-quickstart__card,
	.docs-grid__card,
	.docs-paths__chips > li {
		opacity: 0;
		animation: docs-rise var(--dur-ink) var(--ease-ink) forwards;
	}
	.docs-hero__kicker { animation-delay:   0ms; }
	.docs-hero__title  { animation-delay: 120ms; }
	.docs-hero__lede   { animation-delay: 280ms; }
	.docs-quickstart__card { animation-delay: 460ms; }
	.docs-grid__card { animation-delay: calc(680ms + var(--card-i, 0) * 100ms); }
	.docs-paths__chips > li { animation-delay: 1100ms; }

	@media (prefers-reduced-motion: reduce) {
		.docs-hero__kicker,
		.docs-hero__title,
		.docs-hero__lede,
		.docs-quickstart__card,
		.docs-grid__card,
		.docs-paths__chips > li {
			opacity: 1;
			animation: none;
		}
	}
</style>
