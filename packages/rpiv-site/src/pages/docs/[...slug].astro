---
import type { GetStaticPaths } from "astro";
import { render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { DOCS_ROOT_ID, getPublishedDocs } from "../../lib/docs";

export const getStaticPaths: GetStaticPaths = async () => {
	const docs = await getPublishedDocs();
	// The root entry renders at /docs (see index.astro); building it here too
	// would duplicate the page at /docs/getting-started.
	return docs
		.filter((entry) => entry.id !== DOCS_ROOT_ID)
		.map((entry) => ({
			params: { slug: entry.id },
			props: { entry },
		}));
};

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<DocsLayout
	title={`${entry.data.title} · rpiv-pi docs`}
	description={entry.data.description}
	headings={headings}
	docArticle={{ section: entry.data.section }}
>
	<article class="prose prose--docs" data-pagefind-body>
		<h1 data-pagefind-meta="title">{entry.data.title}</h1>
		{entry.data.description && (
			<p class="docs-lede">{entry.data.description}</p>
		)}
		<Content />
	</article>
</DocsLayout>

<!-- .docs-lede lives in src/styles/prose.css alongside the rest of the
     shared docs typography. No page-local overrides here. -->
