{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "description": { "type": "string" },
    "inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dispatches": {
      "type": "array",
      "items": { "type": "string" }
    },
    "body": { "type": "string" }
  },
  "required": ["id", "description", "body"]
}
