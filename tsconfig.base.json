{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"lib": [
			"ES2022"
		],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false,
		"noEmit": true,
		"types": [
			"node"
		]
	},
	"include": [
		"packages/*/**/*.ts",
		"test/**/*.ts",
		"vitest.config.ts"
	],
	"exclude": [
		"**/node_modules/**",
		"**/.pi/**",
		"**/.rpiv/**",
		"**/thoughts/**",
		"**/dist/**",
		"packages/rpiv-site/**"
	]
}
